#!/usr/bin/env bash
set -euo pipefail

if [[ "${SOPIFY_DISABLE_RELEASE_HOOK:-0}" == "1" ]]; then
  exit 0
fi

MESSAGE_FILE="${1:-}"
if [[ -z "$MESSAGE_FILE" || ! -f "$MESSAGE_FILE" ]]; then
  exit 0
fi

ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$ROOT_DIR" || ! -d "$ROOT_DIR" ]]; then
  exit 0
fi

append_trailer() {
  local file="$1"
  local key="$2"
  local value="$3"
  if grep -Eiq "^${key}:\s*" "$file"; then
    return 0
  fi
  printf '\n%s: %s\n' "$key" "$value" >>"$file"
}

STATE_FILE="$(git -C "$ROOT_DIR" rev-parse --git-path .sopify-release-sync-state)"

# Avoid duplicate trailers when amending a commit already stamped by this hook.
if grep -Eiq '^Release-Version:\s*' "$MESSAGE_FILE"; then
  rm -f "$STATE_FILE"
  exit 0
fi

if [[ ! -f "$STATE_FILE" ]]; then
  exit 0
fi

RELEASE_VERSION=""
RELEASE_DATE=""

while IFS='=' read -r key value; do
  case "$key" in
    RELEASE_VERSION)
      RELEASE_VERSION="$value"
      ;;
    RELEASE_DATE)
      RELEASE_DATE="$value"
      ;;
  esac
done <"$STATE_FILE"

if [[ -z "$RELEASE_VERSION" || -z "$RELEASE_DATE" ]]; then
  echo "[sopify-release-hook] Invalid release state file: $STATE_FILE" >&2
  exit 1
fi

append_trailer "$MESSAGE_FILE" "Release-Sync" "yes"
append_trailer "$MESSAGE_FILE" "Release-Version" "$RELEASE_VERSION"
append_trailer "$MESSAGE_FILE" "Release-Date" "$RELEASE_DATE"

rm -f "$STATE_FILE"
